generator client {
  provider      = "prisma-client-js"
  // Include common Linux/OpenSSL targets used by cPanel/o2switch-like hosts
  // so the standalone build can boot even when the server runtime differs
  // from the local machine that generated the client.
  binaryTargets = ["native", "debian-openssl-1.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "rhel-openssl-1.0.x", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum NewsStatus {
  DRAFT
  PUBLISHED
}

enum EventStatus {
  UPCOMING
  COMPLETED
}

enum NavigationSection {
  PRIMARY
  SECONDARY
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  name              String
  passwordHash      String
  role              UserRole       @default(USER)
  isActive          Boolean        @default(true)
  avatarUrl         String?
  city              String?
  phone             String?
  formerJobTitle    String?
  formerDepartment  String?
  bio               String?
  joinedAmicaleAt   DateTime?
  sessions          Session[]
  authoredArticles NewsArticle[] @relation("ArticleAuthor")
  uploadedDocuments Document[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  lastSeenAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model NewsCategory {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String?
  articles    NewsArticle[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([name])
}

model NewsArticle {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  excerpt       String
  content       String
  coverImageUrl String?
  status        NewsStatus    @default(DRAFT)
  featured      Boolean       @default(false)
  publishedAt   DateTime?
  categoryId    String
  authorId      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  category      NewsCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  author        User?         @relation("ArticleAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  images        NewsImage[]

  @@index([categoryId])
  @@index([status, publishedAt])
}

model NewsImage {
  id        String      @id @default(cuid())
  articleId String
  url       String
  alt       String?
  caption   String?
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  article   NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, sortOrder])
}

model Event {
  id            String       @id @default(cuid())
  title         String
  slug          String       @unique
  summary       String
  description   String
  location      String
  coverImageUrl String?
  startAt       DateTime
  endAt         DateTime?
  status        EventStatus  @default(UPCOMING)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  albums        PhotoAlbum[]

  @@index([status, startAt])
}

model PhotoAlbum {
  id            String       @id @default(cuid())
  title         String
  slug          String       @unique
  summary       String
  coverImageUrl String?
  eventId       String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  event         Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  photos        PhotoItem[]

  @@index([eventId])
}

model PhotoItem {
  id        String     @id @default(cuid())
  albumId   String
  url       String
  alt       String?
  caption   String?
  sortOrder Int        @default(0)
  createdAt DateTime   @default(now())
  album     PhotoAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId, sortOrder])
}

model Document {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String?
  fileName      String
  filePath      String
  mimeType      String?
  sizeBytes     Int?
  uploadedById  String
  createdAt     DateTime @default(now())
  uploadedBy    User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([uploadedById, createdAt])
}

model NavigationItem {
  id        String            @id @default(cuid())
  label     String
  href      String?
  icon      String
  section   NavigationSection
  parentId  String?
  sortOrder Int               @default(0)
  isVisible Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  parent    NavigationItem?   @relation("NavigationChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  NavigationItem[]  @relation("NavigationChildren")

  @@index([section, sortOrder])
  @@index([parentId, sortOrder])
}
